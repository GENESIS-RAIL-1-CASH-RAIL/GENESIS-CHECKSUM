{
  "name": "genesis-checksum",
  "version": "0.1.0",
  "description": "Behavioural integrity watchdog. Verifies the work is actually happening, not just that the process is alive.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "mkdir -p dist/signatures && cp -r src/signatures/* dist/signatures/",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "deadman": "node deadman/deadman.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "node-fetch": "^2.6.9"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
